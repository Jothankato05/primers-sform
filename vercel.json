{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/health",
            "destination": "/api/health.py"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}